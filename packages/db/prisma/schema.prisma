generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProductType {
  PACK
  BOX
  ETB
  BUNDLE
}

enum Role {
  CUSTOMER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum CardCondition {
  MINT
  NEAR_MINT
  LIGHTLY_PLAYED
  MODERATELY_PLAYED
  HEAVILY_PLAYED
  DAMAGED
}

enum ListingType {
  TRADE
  SALE
  TRADE_OR_SALE
}

enum ListingStatus {
  ACTIVE
  PENDING
  COMPLETED
  CANCELLED
}

enum OfferType {
  CASH
  TRADE
  MIXED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum ReportReason {
  FAKE_LISTING
  ITEM_NOT_RECEIVED
  WRONG_ITEM_SENT
  HARASSMENT
  SCAM
  OTHER
}

enum XPReason {
  LISTING_CREATED
  OFFER_SENT
  TRADE_COMPLETED
  SALE_COMPLETED
  CARD_ACQUIRED
  ORDER_PLACED
  BONUS_FIRST_LISTING
  BONUS_FIRST_TRADE
  BONUS_FIRST_SALE
  REFERRAL_BONUS
}

enum BadgeTier {
  COMMON
  RARE
  LEGENDARY
}

enum BadgeCategory {
  TRADING
  SELLING
  COLLECTING
  LISTING
  LEVEL
  SPECIAL
}

// ─── Store ────────────────────────────────────────────────────────────────────

model Set {
  id          String    @id @default(cuid())
  name        String
  series      String
  slug        String    @unique
  releaseDate DateTime
  logoUrl     String?
  symbolUrl   String?
  products    Product[]
  tcgSet      TcgSet?
  createdAt   DateTime  @default(now())
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  type        ProductType
  price       Decimal
  stock       Int         @default(0)
  imageUrl    String?
  description String?
  setId       String
  set         Set         @relation(fields: [setId], references: [id])
  orderItems  OrderItem[]
  cartItems   CartItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique @db.VarChar(254)
  name                String?             @db.VarChar(50)
  password            String?
  role                Role                @default(CUSTOMER)
  riskScore           Int                 @default(0)
  referralCode        String?             @unique
  referredBy          String?
  emailVerified       DateTime?
  verificationTokens  VerificationToken[]
  orders              Order[]
  cart                Cart?
  listings            Listing[]
  offers              TradeOffer[]
  userCards           UserCard[]
  xp                  UserXP?
  xpEvents            XPEvent[]
  badges              UserBadge[]
  profile             UserProfile?
  reviewsReceived     SellerReview[]      @relation("ReviewsReceived")
  reviewsGiven        SellerReview[]      @relation("ReviewsGiven")
  reportsFiled        Report[]            @relation("ReportsFiled")
  reportsReceived     Report[]            @relation("ReportsReceived")
  createdAt           DateTime            @default(now())

  @@index([riskScore])
  @@index([emailVerified])
}

// Email-verification tokens. Raw token is sent to the user; only sha256 hash
// is stored. One-shot: deleted on use; old tokens deleted on resend.
model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int

  @@index([cartId])
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  status           OrderStatus @default(PENDING)
  total            Decimal
  items            OrderItem[]
  shippingName     String?
  shippingAddress  String?
  shippingCity     String?
  shippingPostcode String?
  shippingCountry  String?
  stripeSessionId  String?     @unique
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([userId, status, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  priceAtTime Decimal

  @@index([orderId])
}

// ─── TCG Card Database ────────────────────────────────────────────────────────

model TcgSet {
  id           String        @id   // pokemontcg.io ID e.g. "sv3"
  name         String
  series       String
  printedTotal Int
  releaseDate  DateTime?
  symbolUrl    String?
  logoUrl      String?
  cards        PokemonCard[]
  storeSetId   String?       @unique
  storeSet     Set?          @relation(fields: [storeSetId], references: [id])
  createdAt    DateTime      @default(now())
}

model PokemonCard {
  id         String     @id   // pokemontcg.io card ID e.g. "sv3-36"
  name       String
  number     String
  rarity     String?
  artist     String?
  imageSmall String?
  imageLarge String?
  tcgSetId   String
  tcgSet     TcgSet     @relation(fields: [tcgSetId], references: [id])
  userCards  UserCard[]
  createdAt  DateTime   @default(now())
}

// ─── Inventory ────────────────────────────────────────────────────────────────

model UserCard {
  id         String                @id @default(cuid())
  userId     String
  user       User                  @relation(fields: [userId], references: [id])
  cardId     String
  card       PokemonCard           @relation(fields: [cardId], references: [id])
  condition  CardCondition
  quantity   Int                   @default(1)
  foil       Boolean               @default(false)
  acquiredAt DateTime              @default(now())
  listings   Listing[]
  offerItems OfferItem[]
  featuredIn ProfileFeaturedCard[]

  @@unique([userId, cardId, condition, foil])
  @@index([userId, cardId])
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id])
  userCardId  String
  userCard    UserCard      @relation(fields: [userCardId], references: [id])
  quantity    Int           @default(1)
  listingType ListingType
  askingPrice Decimal?
  status      ListingStatus @default(ACTIVE)
  description String?       @db.VarChar(2000)
  offers      TradeOffer[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([sellerId, status])
}

model TradeOffer {
  id                 String         @id @default(cuid())
  listingId          String
  listing            Listing        @relation(fields: [listingId], references: [id])
  offererId          String
  offerer            User           @relation(fields: [offererId], references: [id])
  offerType          OfferType
  cashAmount         Decimal?
  items              OfferItem[]
  reviews            SellerReview[]
  reports            Report[]
  message            String?        @db.VarChar(1000)
  status             OfferStatus    @default(PENDING)
  sellerConfirmed    Boolean        @default(false)
  offererConfirmed   Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([offererId, status])
  @@index([listingId, status])
}

model OfferItem {
  id         String     @id @default(cuid())
  offerId    String
  offer      TradeOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  userCardId String
  userCard   UserCard   @relation(fields: [userCardId], references: [id])
  quantity   Int        @default(1)

  @@index([offerId])
}

// ─── Progression ──────────────────────────────────────────────────────────────

model UserXP {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id])
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

model XPEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  reason    XPReason
  entityId  String
  createdAt DateTime @default(now())

  @@unique([userId, reason, entityId])
  @@index([userId])
}

model Badge {
  id          String        @id
  name        String
  description String
  tier        BadgeTier
  category    BadgeCategory
  iconKey     String
  userBadges  UserBadge[]
}

model UserBadge {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  badgeId     String
  badge       Badge             @relation(fields: [badgeId], references: [id])
  earnedAt    DateTime          @default(now())
  showcasedIn ProfileShowcase[]

  @@unique([userId, badgeId])
  @@index([userId])
}

// ─── Profile Customization ────────────────────────────────────────────────────

model UserProfile {
  userId    String                @id
  user      User                  @relation(fields: [userId], references: [id])
  avatarId  String                @default("gengar") @db.VarChar(32)
  themeId   String                @default("purple") @db.VarChar(32)
  bio       String?               @db.VarChar(160)
  updatedAt DateTime              @updatedAt
  showcase  ProfileShowcase[]
  featured  ProfileFeaturedCard[]
}

model ProfileShowcase {
  id          String      @id @default(cuid())
  profileId   String
  profile     UserProfile @relation(fields: [profileId], references: [userId], onDelete: Cascade)
  userBadgeId String
  userBadge   UserBadge   @relation(fields: [userBadgeId], references: [id])
  position    Int

  @@unique([profileId, position])
  @@unique([profileId, userBadgeId])
}

model ProfileFeaturedCard {
  id         String      @id @default(cuid())
  profileId  String
  profile    UserProfile @relation(fields: [profileId], references: [userId])
  userCardId String
  userCard   UserCard    @relation(fields: [userCardId], references: [id], onDelete: Cascade)
  position   Int

  @@unique([profileId, position])
  @@unique([profileId, userCardId])
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id             String       @id @default(cuid())
  reporterId     String
  reporter       User         @relation("ReportsFiled", fields: [reporterId], references: [id])
  reportedId     String
  reported       User         @relation("ReportsReceived", fields: [reportedId], references: [id])
  offerId        String?
  offer          TradeOffer?  @relation(fields: [offerId], references: [id])
  reason         ReportReason
  description    String?      @db.VarChar(1000)
  adminConfirmed Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([reporterId, offerId])
  @@index([reportedId])
  @@index([reporterId, createdAt])
  @@index([adminConfirmed, createdAt])
}

// ─── Security ────────────────────────────────────────────────────────────────

// Fixed-window rate-limit hit log. One row per attempted action;
// `checkAndRecordRateLimit` counts rows in the window and inserts a new one.
model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// ─── Reviews ─────────────────────────────────────────────────────────────────

model SellerReview {
  id         String     @id @default(cuid())
  sellerId   String
  seller     User       @relation("ReviewsReceived", fields: [sellerId], references: [id])
  reviewerId String
  reviewer   User       @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  offerId    String
  offer      TradeOffer @relation(fields: [offerId], references: [id])
  rating     Int
  comment    String?    @db.VarChar(1000)
  createdAt  DateTime   @default(now())

  @@unique([reviewerId, offerId])
  @@index([sellerId])
}
