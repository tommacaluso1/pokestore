# ─── Database (Prisma + Neon / Postgres) ─────────────────────────────────────
# DATABASE_URL uses pgbouncer-pooled connection for runtime.
# DIRECT_URL is required by `prisma migrate` (it needs a direct, unpooled conn).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Auth (Auth.js v5) ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with: openssl rand -base64 32"
# Set to true if running behind a proxy on a non-localhost URL.
# AUTH_TRUST_HOST=true

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Stripe (optional — required for checkout) ───────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── TCG card ingestion (admin feature) ──────────────────────────────────────
# Optional: pokemontcg.io API key lifts the 30 req/min rate limit.
POKEMONTCG_API_KEY=""
